# Must be at least 32 characters (JWT signing). Generate: openssl rand -hex 32
DJANGO_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
DEBUG=True
ALLOWED_HOSTS=*
DATABASE_URL=sqlite:///db.sqlite3
ML_SCORING_SERVICE_URL=http://localhost:8001/score
ML_SERVICE_TIMEOUT_SECONDS=3
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Groq API for AI-powered transaction analysis (get a free key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=10

# Optional: used by `python manage.py create_demo_reviewer`
ESO_REVIEWER_PASSWORD=

# --- Production (Render + Vercel) ---
# Render injects this automatically for the live service URL
# RENDER_EXTERNAL_HOSTNAME=eso-backend.onrender.com
# Set this to your Vercel frontend URL:
# VERCEL_FRONTEND_URL=https://eso-frontend.vercel.app

# --- Keep-alive ---
# Free Render instances spin down after 15 min idle.
# Set up a free cron-job.org or UptimeRobot monitor hitting:
#   GET https://your-app.onrender.com/api/health/
# every 10 minutes to keep it warm.
